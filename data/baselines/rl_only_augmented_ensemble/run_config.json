    0.1,
    0.3
  ],
  "noise_sigma": 0.001,
  "dqn_learning_rate": 0.0001,
  "dqn_batch_size": 64,
  "dqn_buffer_size": 100000,
  "dqn_learning_starts": 2000,
  "dqn_train_freq": 4,
  "dqn_gradient_steps": 1,
  "dqn_target_update_interval": 500,
  "dqn_tau": 1.0,
  "dqn_gamma": 0.99,
  "dqn_exploration_fraction": 0.2,
  "dqn_exploration_final_eps": 0.02,
  "net_arch": [
    128,
    128
  ]
}