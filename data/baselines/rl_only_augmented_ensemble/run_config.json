{
  "input_path": "data/spy_market_data.csv",
  "output_dir": "data/baselines/rl_only_augmented_ensemble",
  "ticker": "SPY",
  "train_timesteps": 200000,
  "initial_amount": 10000.0,
  "transaction_cost_pct": 0.001,
  "reward_window_k": 3,
  "n_seeds": 5,
  "base_seed": 42,
  "augmentation_modes": [
    "none",
    "shift",
    "filter",
    "noise"
  ],
